# Copy to `.env.local` for `npm run dev` (Next.js loads `.env.local` automatically).
# In production, set the same variables in your host (e.g. Vercel → Environment Variables).

# Required for POST /api/scores (Bearer token matches this value).
TYPA_API_SECRET=

# Optional — salt for SHA-256 IP hashing. Use a stable random value in production.
TYPA_IP_SALT=

# Optional — Postgres connection string (e.g. Neon). When set, scores use the database
# instead of `data/scores.json` (or `/tmp` on Vercel). The app creates the table on first use.
DATABASE_URL=

# Example (Neon):
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
