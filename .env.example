# Typa
#
# Next.js app (`web/`): copy `web/.env.example` to `web/.env.local` and set values there.
# Use `DATABASE_URL` for Neon (or any Postgres); optional — omit for local JSON file storage.
#
# Go game (optional — score uploads use the shell, not `.env`):
#   export TYPA_API_URL="https://<your-deployment>.vercel.app"
#   export TYPA_API_SECRET="same secret as TYPA_API_SECRET for the web app"
#   export TYPA_CLIENT_IP=""   # optional; real client IP when behind a proxy/SSH
